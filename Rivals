local ProjectileCache = {}
workspace.ChildAdded:Connect(function(v)
    if v.Name == "CoreProjectile" or v.Name == "Slingshot" or v.Name == "Daggers" or v.Name == "Bow" then
        ProjectileCache[v] = true
        task.delay(3, function()
            if ProjectileCache[v] then
                ProjectileCache[v] = nil
            end
        end)
    end
end)

rs.RenderStepped:Connect(function(dt)
   if idk and hide and hide.Character then
      local targetHitbox = hide.Character:FindFirstChild("HitboxHeadSmall") 
                           or hide.Character:FindFirstChild("HitboxHead") 
                           or hide.Character:FindFirstChild("Head")
      
      if targetHitbox and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
         local hrp = lp.Character.HumanoidRootPart
         
         if not isSpoofing then
             if hrp.CFrame.X == hrp.CFrame.X then dTypes[1] = hrp.CFrame end
             isSpoofing = true
         end
         
         pingpong_pos = (pingpong_pos == 500000) and -500000 or 500000
         local randX = math.random(-50000, 50000)
         local randY = math.random(-50000, 50000)
         local randZ = math.random(-50000, 50000)
         
         hrp.CFrame = CFrame.new(pingpong_pos + randX, 100000 + randY, pingpong_pos + randZ) 
                      * CFrame.Angles(math.rad(math.random(-360,360)), math.rad(math.random(-360,360)), math.rad(math.random(-360,360)))
         
         local maxV = 500000
         hrp.AssemblyLinearVelocity = Vector3.new(math.random(-maxV, maxV), math.random(-maxV, maxV), math.random(-maxV, maxV))
         hrp.AssemblyAngularVelocity = Vector3.new(math.random(-maxV, maxV), math.random(-maxV, maxV), math.random(-maxV, maxV))
         
         targetHitbox.CFrame = hrp.CFrame * CFrame.new(0, -15, 0)
         
         for v, _ in pairs(ProjectileCache) do
            if v and v.Parent and v:IsA("BasePart") then
               v.CFrame = targetHitbox.CFrame 
               pcall(function()
                  firetouchinterest(targetHitbox, v, 0)
                  firetouchinterest(targetHitbox, v, 1)
               end)
            end
            ProjectileCache[v] = nil
         end
      end
   else
      if isSpoofing and cHrp and dTypes[1] then
          cHrp.CFrame = dTypes[1]
          cHrp.AssemblyLinearVelocity = Vector3.zero
          cHrp.AssemblyAngularVelocity = Vector3.zero
          isSpoofing = false
      elseif cHrp and cHrp.CFrame.X == cHrp.CFrame.X then
          dTypes[1] = cHrp.CFrame
      end
   end
end)

