local dTypes = {CFrame.new(), Vector3.new()}
local isSpoofing = false
local cChar, cHrp, cHum, cHead

local idk = false
local pingpong_pos = 500000

local function updateCache(c)
    cChar = c
    if cChar then
        cHrp = cChar:WaitForChild("HumanoidRootPart", 3)
        cHum = cChar:WaitForChild("Humanoid", 3)
        cHead = cChar:WaitForChild("Head", 3)
        if cHrp then
            dTypes[1] = cHrp.CFrame
        end
    else
        cHrp, cHum, cHead = nil, nil, nil
    end
end

lp.CharacterAdded:Connect(updateCache)
if lp.Character then task.spawn(function() updateCache(lp.Character) end) end

local oIndex
oIndex = hookmetamethod(g, "__index", newcclosure(function(self, key)
    if idk and isSpoofing and not checkcaller() and key == "CFrame" and cChar and cHrp and cHum and cHum.Health > 0 then
        if self == cHrp then
            return dTypes[1] or CFrame.new()
        elseif self == cHead then
            return dTypes[1] and dTypes[1] * CFrame.new(0, 1.5, 0) or CFrame.new()
        end
    end
    return oIndex(self, key)
end))

function if_player_is_on_round_or_another(player)
    return player:GetAttribute("EnvironmentID") ~= nil
end

function chid_to_id(chid)
    return string.byte(chid or string.char(0))
end

function get_every_player_in_Environment_but_without_thisteam(id,id2)
    local output = {}
    for k, v in pairs(plrs:GetChildren()) do
        if not (game.PlaceId == 129604661913557 or game.PlaceId == 71874690745115) then
            if v:IsA("Player") and if_player_is_on_round_or_another(v) and chid_to_id(v:GetAttribute("EnvironmentID")) == id and chid_to_id(v:GetAttribute("TeamID")) ~= id2 then
                output[v] = true
            end
        end
        if (game.PlaceId == 129604661913557 or game.PlaceId == 71874690745115) then
            if v:IsA("Player") and if_player_is_on_round_or_another(v) and chid_to_id(v:GetAttribute("EnvironmentID")) == id then
                output[v] = true
            end
        end
    end
    return output
end

